pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'python -m pip install -r requirements.txt'
            }
        }

        stage('Run Tests') {
            steps {
                bat 'pytest tests -v'
            }
        }

        stage('Run App Check') {
            steps {
                bat 'python app/app.py'
            }
        }
    }
}